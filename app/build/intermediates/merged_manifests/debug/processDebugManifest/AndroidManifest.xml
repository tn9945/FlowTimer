<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.flowtimer"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="36" />

    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <permission
        android:name="com.example.flowtimer.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.flowtimer.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/flow_timer_app_icon_transparent"
        android:label="@string/app_name"
        android:roundIcon="@drawable/flow_timer_app_icon_transparent"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.FlowTimer" >
        <activity
            android:name="com.example.flowtimer.DeveloperModeActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.FocusStatsDetailActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.FocusStatsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.FocusResultActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.ShopActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.CustomizeActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.WithdrawActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.SignupActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.CharacterSelectActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.GameActivity"
            android:exported="false" />
        <activity
            android:name="com.example.flowtimer.LoginActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.flowtimer.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>