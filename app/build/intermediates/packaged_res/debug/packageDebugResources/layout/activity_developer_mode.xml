<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="개발자 모드" android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDeveloperSummary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="테스트 안내" android:textColor="@color/flow_text_hint" android:textSize="15sp"/>
        <TextView android:id="@+id/tvUsageAccessStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="사용 기록 접근 설정 상태" android:textColor="@color/flow_text_primary" android:textSize="15sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvBackupStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="백업 상태" android:textColor="@color/flow_text_primary" android:textSize="15sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnClearFocusRecords" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="20dp" android:background="@drawable/bg_button_red" android:backgroundTint="@color/flow_button_danger" android:text="집중 활동 기록 강제 초기화" android:textColor="@color/white" android:textAllCaps="false"/>
        <Button android:id="@+id/btnCreateSampleData" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_orange" android:backgroundTint="@color/flow_button_game" android:text="테스트 더미 기록 생성" android:textColor="@color/white" android:textAllCaps="false"/>
        <Button android:id="@+id/btnExportBackup" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_developer" android:backgroundTint="@color/flow_button_developer" android:text="집중 기록 백업 생성" android:textColor="@color/white" android:textAllCaps="false"/>
        <Button android:id="@+id/btnImportBackup" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_developer" android:backgroundTint="@color/flow_button_developer" android:text="백업 복원" android:textColor="@color/white" android:textAllCaps="false"/>
        <Button android:id="@+id/btnOpenUsageSettings" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_stats" android:backgroundTint="@color/flow_button_stats" android:text="사용 기록 접근 설정 열기" android:textColor="@color/white" android:textAllCaps="false"/>
        <Button android:id="@+id/btnGoMain" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_main" android:backgroundTint="@color/flow_button_main" android:text="메인 화면으로 이동" android:textColor="@color/flow_button_main_text" android:textAllCaps="false"/>
    </LinearLayout>
</ScrollView>
