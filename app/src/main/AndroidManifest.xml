<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/flow_timer_app_icon_transparent"
        android:label="@string/app_name"
        android:roundIcon="@drawable/flow_timer_app_icon_transparent"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlowTimer">

        <receiver
            android:name=".FocusNotificationActionReceiver"
            android:enabled="true"
            android:exported="false" />
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".ConscienceFocusService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <service
            android:name=".FocusGuardService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <activity
            android:name=".BlockedAppActivity"
            android:exported="false" />
        <activity
            android:name=".AllowedAppsActivity"
            android:exported="false" />
        <activity
            android:name=".StrictFocusActivity"
            android:exported="false" />
        <activity
            android:name=".FocusModeSelectActivity"
            android:exported="false" />
        <activity
            android:name=".DeveloperModeActivity"
            android:exported="false" />
        <activity
            android:name=".FocusStatsDetailActivity"
            android:exported="false" />
        <activity
            android:name=".FocusStatsActivity"
            android:exported="false" />
        <activity
            android:name=".FocusResultActivity"
            android:exported="false" />
        <activity
            android:name=".ShopActivity"
            android:exported="false" />
        <activity
            android:name=".CustomizeActivity"
            android:exported="false" />
        <activity
            android:name=".WithdrawActivity"
            android:exported="false" />
        <activity
            android:name=".SignupActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".CharacterSelectActivity"
            android:exported="false" />
        <activity
            android:name=".GameActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
