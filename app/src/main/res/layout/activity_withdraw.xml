<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_horizontal" android:orientation="vertical" android:paddingStart="28dp" android:paddingTop="48dp" android:paddingEnd="28dp" android:paddingBottom="36dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Flow Timer" android:textColor="@color/flow_sky" android:textSize="32sp" android:textStyle="bold"/>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="22dp" android:background="@color/flow_line"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="회원 탈퇴" android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:text="아이디와 비밀번호를 다시 입력해 주십시오." android:textColor="@color/flow_text_hint" android:textSize="15sp"/>
        <EditText android:id="@+id/etUserId" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="24dp" android:background="@drawable/bg_edit_text" android:hint="아이디" android:inputType="textVisiblePassword|textNoSuggestions" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="@color/flow_text_primary" android:textColorHint="@color/flow_text_hint"/>
        <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="14dp" android:background="@drawable/bg_edit_text" android:hint="비밀번호" android:inputType="textPassword" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="@color/flow_text_primary" android:textColorHint="@color/flow_text_hint"/>
        <Button android:id="@+id/btnWithdraw" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="22dp" android:background="@drawable/bg_button_red" android:text="회원 탈퇴" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" android:backgroundTint="@color/flow_button_danger"/>
        <Button android:id="@+id/btnGoMain" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_main" android:text="메인 화면으로 이동" android:textAllCaps="false" android:textColor="@color/flow_button_main_text" android:textSize="16sp" android:textStyle="bold" android:backgroundTint="@color/flow_button_main"/>
        <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvCancel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="취소" android:textColor="@color/flow_sky_dark" android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
