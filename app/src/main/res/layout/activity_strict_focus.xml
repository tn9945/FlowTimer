<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:gravity="center" android:orientation="vertical" android:padding="32dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="상호작용 금지 집중 중" android:textColor="@color/flow_text_hint" android:textSize="16sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tvStrictTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="25:00" android:textColor="@color/flow_text_primary" android:textSize="64sp" android:textStyle="bold"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center" android:text="집중 중에는 타이머 화면을 유지합니다." android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
    <Button android:id="@+id/btnFinishStrictFocus" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="40dp" android:background="@drawable/bg_button_red" android:backgroundTint="@null" android:text="집중 종료" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
</LinearLayout>
