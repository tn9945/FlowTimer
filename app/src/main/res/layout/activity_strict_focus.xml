<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:gravity="center" android:orientation="vertical" android:padding="32dp">
    <TextView android:id="@+id/tvStrictModeTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="강제 집중 모드" android:textColor="@color/flow_text_hint" android:textSize="16sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tvStrictTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="00:00" android:textColor="@color/flow_text_primary" android:textSize="64sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tvStrictGuide" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center" android:text="선택한 앱만 예외적으로 사용할 수 있습니다." android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
    <Button android:id="@+id/btnOpenAllowedApps" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="32dp" android:background="@drawable/bg_button_developer" android:backgroundTint="@color/flow_button_developer" android:text="허용 앱 열기" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
    <Button android:id="@+id/btnFinishStrictFocus" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_red" android:backgroundTint="@null" android:text="집중 종료" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
</LinearLayout>
