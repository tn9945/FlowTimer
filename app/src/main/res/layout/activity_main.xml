<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Flow Timer" android:textColor="@color/flow_sky" android:textSize="30sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvWelcome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="30dp" android:text="환영합니다." android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvUserId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="ID" android:textColor="@color/flow_text_hint" android:textSize="16sp"/>
        <TextView android:id="@+id/tvTimer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="42dp" android:gravity="center" android:text="00:00" android:textColor="@color/flow_text_primary" android:textSize="56sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
            <Button android:id="@+id/btnStartFocus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="5dp" android:background="@drawable/bg_button_focus" android:backgroundTint="@color/flow_button_focus" android:text="집중 시작" android:textColor="@color/white" android:textAllCaps="false"/>
            <Button android:id="@+id/btnResetFocus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="5dp" android:background="@drawable/bg_button_neutral" android:backgroundTint="@color/flow_button_neutral" android:text="초기화" android:textColor="@color/white" android:visibility="gone" android:textAllCaps="false"/>
        </LinearLayout>
        <Button android:id="@+id/btnStats" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="14dp" android:background="@drawable/bg_button_stats" android:backgroundTint="@color/flow_button_stats" android:text="집중 기록 통계" android:textAllCaps="false" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnGameStart" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="14dp" android:background="@drawable/bg_button_orange" android:backgroundTint="@color/flow_button_game" android:text="Game" android:textAllCaps="false" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@drawable/bg_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오늘 목표" android:textColor="@color/flow_text_primary" android:textSize="17sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="집중 기록과 통계를 꾸준히 관리합니다." android:textColor="@color/flow_sky_dark" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>
        <Button android:id="@+id/btnLogout" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="28dp" android:background="@drawable/bg_button_red" android:backgroundTint="@color/flow_button_danger" android:text="로그아웃" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvWithdraw" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:layout_marginTop="18dp" android:text="회원 탈퇴" android:textColor="@color/flow_red" android:textSize="15sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDeveloperMode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="end" android:layout_marginTop="24dp" android:text="개발자 모드" android:textColor="@color/flow_text_hint" android:textSize="13sp" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
