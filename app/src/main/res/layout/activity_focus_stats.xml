<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="집중 기록 통계" android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="누적 세션 수" android:textStyle="bold"/>
        <TextView android:id="@+id/tvTotalSession" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="0" android:textSize="18sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="누적 순집중 시간" android:textStyle="bold"/>
        <TextView android:id="@+id/tvTotalFocus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="00시간 00분 00초" android:textSize="18sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="누적 휴식 시간" android:textStyle="bold"/>
        <TextView android:id="@+id/tvTotalBreak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="00시간 00분 00초" android:textSize="18sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="누적 학습 시간" android:textStyle="bold"/>
        <TextView android:id="@+id/tvTotalStudy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="00시간 00분 00초" android:textSize="18sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="누적 방해 시간" android:textStyle="bold"/>
        <TextView android:id="@+id/tvTotalDistraction" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="00시간 00분 00초" android:textSize="18sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="평균 집중 점수" android:textStyle="bold"/>
        <TextView android:id="@+id/tvAverageScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="0.0점" android:textSize="18sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="총 통계 보기" android:textStyle="bold"/>
        <LinearLayout android:id="@+id/layoutOverallStats" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_card" android:orientation="vertical" android:padding="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:gravity="center" android:orientation="horizontal">
            <Button android:id="@+id/btnPeriodDaily" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_button_detail" android:backgroundTint="@color/flow_button_detail" android:text="일간" android:textColor="@color/white" android:textAllCaps="false"/>
            <Button android:id="@+id/btnPeriodWeekly" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginHorizontal="6dp" android:layout_weight="1" android:background="@drawable/bg_button_detail" android:backgroundTint="@color/flow_button_detail" android:text="주간" android:textColor="@color/white" android:textAllCaps="false"/>
            <Button android:id="@+id/btnPeriodMonthly" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginStart="6dp" android:layout_weight="1" android:background="@drawable/bg_button_detail" android:backgroundTint="@color/flow_button_detail" android:text="월간" android:textColor="@color/white" android:textAllCaps="false"/>
        </LinearLayout>
        <TextView android:id="@+id/tvPeriodTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="날짜별 통계" android:textStyle="bold"/>
        <LinearLayout android:id="@+id/layoutDailyStats" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_card" android:orientation="vertical" android:padding="8dp"/>
        <Button android:id="@+id/btnDailyDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_button_detail" android:backgroundTint="@color/flow_button_detail" android:text="기간별 자세히 보기" android:textColor="@color/white" android:textAllCaps="false"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="시간대별 통계" android:textStyle="bold"/>
        <LinearLayout android:id="@+id/layoutHourlyStats" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_card" android:orientation="vertical" android:padding="8dp"/>
        <Button android:id="@+id/btnHourlyDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_button_detail" android:backgroundTint="@color/flow_button_detail" android:text="시간대별 자세히 보기" android:textColor="@color/white" android:textAllCaps="false"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="앱별 통계" android:textStyle="bold"/>
        <LinearLayout android:id="@+id/layoutAppStats" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_card" android:orientation="vertical" android:padding="8dp"/>
        <Button android:id="@+id/btnAppDetail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_button_detail" android:backgroundTint="@color/flow_button_detail" android:text="앱별 자세히 보기" android:textColor="@color/white" android:textAllCaps="false"/>
        <Button android:id="@+id/btnGoMain" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="24dp" android:background="@drawable/bg_button_main" android:backgroundTint="@color/flow_button_main" android:text="메인 화면으로 이동" android:textColor="@color/flow_button_main_text" android:textAllCaps="false"/>
    </LinearLayout>
</ScrollView>
