<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:gravity="center" android:orientation="vertical" android:padding="32dp">
    <ImageView android:layout_width="96dp" android:layout_height="96dp" android:src="@drawable/flow_timer_app_icon_transparent" android:contentDescription="FlowTimer"/>
    <TextView android:id="@+id/tvBlockedMessage" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:gravity="center" android:text="이 앱은 집중하는 동안 사용할 수 없습니다." android:textColor="@color/flow_red" android:textSize="24sp" android:textStyle="bold"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:gravity="center" android:text="집중이 끝나면 이용할 수 있습니다." android:textColor="@color/flow_warning_light" android:textSize="20sp"/>
    <Button android:id="@+id/btnReturnStrictFocus" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="120dp" android:background="@drawable/bg_button_red" android:backgroundTint="@null" android:text="확인" android:textAllCaps="false" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"/>
</LinearLayout>
