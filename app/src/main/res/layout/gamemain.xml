<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:id="@+id/topBar" android:layout_width="match_parent" android:layout_height="70dp" android:background="@color/flow_sky_light" android:gravity="center" android:orientation="horizontal">
        <TextView android:id="@+id/tvCoin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="10dp" android:text="💰 0" android:textSize="16sp"/>
        <TextView android:id="@+id/tvExp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="10dp" android:text="⭐ 0" android:textSize="16sp"/>
        <TextView android:id="@+id/tvTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="10dp" android:text="⏱ 0분" android:textSize="16sp"/>
    </LinearLayout>
    <ImageView android:id="@+id/imgCharacter" android:layout_width="220dp" android:layout_height="220dp" android:layout_below="@id/topBar" android:layout_centerHorizontal="true" android:layout_marginTop="60dp" android:scaleType="fitCenter" android:src="@drawable/screenshot"/>
    <TextView android:id="@+id/tvState" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/imgCharacter" android:layout_centerHorizontal="true" android:layout_marginTop="12dp" android:text="열심히 성장 중" android:textSize="16sp"/>
    <LinearLayout android:id="@+id/bottomMenu" android:layout_width="match_parent" android:layout_height="80dp" android:layout_above="@id/btnGoMainBottom" android:layout_marginBottom="12dp" android:background="@color/flow_sky_light" android:orientation="horizontal" android:paddingBottom="10dp">
        <Button android:id="@+id/btnGacha" android:background="@drawable/bg_button_gacha" android:backgroundTint="@color/flow_button_gacha" android:textColor="@color/white" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="뽑기" android:textAllCaps="false"/>
        <Button android:id="@+id/btnCustomize" android:background="@drawable/bg_button_customize" android:backgroundTint="@color/flow_button_customize" android:textColor="@color/white" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="꾸미기" android:textAllCaps="false"/>
    </LinearLayout>
    <Button android:id="@+id/btnGoMainBottom" android:background="@drawable/bg_button_red" android:backgroundTint="@color/flow_button_danger" android:textColor="@color/white" android:layout_width="match_parent" android:layout_height="56dp" android:layout_alignParentBottom="true" android:layout_margin="16dp" android:text="메인 화면으로 이동" android:textAllCaps="false"/>
</RelativeLayout>
