<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="집중 방식 선택" android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="오늘 집중 방식에 맞는 모드를 선택하십시오." android:textColor="@color/flow_text_hint" android:textSize="15sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="강제 집중 모드" android:textColor="@color/flow_text_primary" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="선택한 앱만 예외적으로 사용할 수 있는 집중 모드입니다." android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
            <Button android:id="@+id/btnForceFocusMode" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_red" android:backgroundTint="@null" android:text="강제 집중 모드로 시작" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="양심 집중 모드" android:textColor="@color/flow_text_primary" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="자유롭게 사용할 수 있지만, 앱 사용 기록을 분석합니다." android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
            <Button android:id="@+id/btnConscienceFocusMode" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_focus" android:backgroundTint="@color/flow_button_focus" android:text="양심 집중 모드로 시작" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>
        <Button android:id="@+id/btnCancelFocusMode" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="18dp" android:background="@drawable/bg_button_neutral" android:backgroundTint="@color/flow_button_neutral" android:text="취소" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
