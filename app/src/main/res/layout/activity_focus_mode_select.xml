<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="집중 방식 선택" android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="집중 중 휴대폰 사용 제한 방식을 선택하십시오." android:textColor="@color/flow_text_hint" android:textSize="15sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="완전 차단 모드" android:textColor="@color/flow_text_primary" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="타이머 전용 화면만 유지합니다.\n\n전화와 메시지를 제외한 앱 이동을 제한하고, 화면 이탈 시도를 기록합니다." android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="주의: 홈 버튼 연타 등 시스템 조작으로 화면을 벗어나려는 시도는 집중 방해 시도로 기록됩니다." android:textColor="@color/flow_warning_light" android:textSize="14sp" android:textStyle="bold"/>
            <Button android:id="@+id/btnFullBlockMode" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_red" android:backgroundTint="@null" android:text="완전 차단 모드로 시작" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="허용 앱 제한 모드" android:textColor="@color/flow_text_primary" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="사용자가 선택한 앱만 예외적으로 열 수 있습니다.\n\n허용되지 않은 앱으로 이동하면 타이머 화면으로 복귀합니다." android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
            <Button android:id="@+id/btnAllowedAppsMode" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_developer" android:backgroundTint="@color/flow_button_developer" android:text="허용 앱 제한 모드로 시작" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="상호작용 허용 모드" android:textColor="@color/flow_text_primary" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="기존 방식처럼 타이머를 진행합니다.\n\n앱 사용 기록을 분석하고 집중 종료 후 AI 요약을 표시합니다." android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
            <Button android:id="@+id/btnFreeMode" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_focus" android:backgroundTint="@color/flow_button_focus" android:text="상호작용 허용 모드로 시작" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>
        <Button android:id="@+id/btnCancelFocusMode" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="18dp" android:background="@drawable/bg_button_neutral" android:backgroundTint="@color/flow_button_neutral" android:text="취소" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
