<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="강제 집중 설정" android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="목표 시간과 집중 중 사용할 앱을 선택하십시오." android:textColor="@color/flow_text_hint" android:textSize="15sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="목표 시간" android:textColor="@color/flow_text_primary" android:textSize="18sp" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgTargetDuration" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical">
                <RadioButton android:id="@+id/rbTarget15" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="15분" android:textColor="@color/flow_text_primary"/>
                <RadioButton android:id="@+id/rbTarget25" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="25분" android:textColor="@color/flow_text_primary" android:checked="true"/>
                <RadioButton android:id="@+id/rbTarget45" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="45분" android:textColor="@color/flow_text_primary"/>
                <RadioButton android:id="@+id/rbTarget60" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="60분" android:textColor="@color/flow_text_primary"/>
            </RadioGroup>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="기본 허용 앱" android:textColor="@color/flow_text_primary" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvDefaultAllowedApps" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="기본 허용 앱을 불러오는 중입니다." android:textColor="@color/flow_text_hint" android:textSize="13sp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="추가 허용 앱" android:textColor="@color/flow_text_primary" android:textSize="18sp" android:textStyle="bold"/>
        <LinearLayout android:id="@+id/layoutAllowedApps" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp"/>
        <Button android:id="@+id/btnStartStrictFocus" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="24dp" android:background="@drawable/bg_button_red" android:backgroundTint="@null" android:text="강제 집중 시작" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnCancelAllowedApps" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_neutral" android:backgroundTint="@color/flow_button_neutral" android:text="취소" android:textAllCaps="false" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
