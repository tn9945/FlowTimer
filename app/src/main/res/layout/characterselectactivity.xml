<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory" android:gravity="center" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="30dp" android:text="캐릭터를 선택합니다." android:textColor="@color/flow_sky" android:textSize="24sp" android:textStyle="bold"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
        <ImageView android:id="@+id/imgRabbit" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="12dp" android:src="@drawable/rabbit"/>
        <ImageView android:id="@+id/imgDog" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="12dp" android:src="@drawable/dog"/>
        <ImageView android:id="@+id/imgBear" android:layout_width="100dp" android:layout_height="100dp" android:layout_margin="12dp" android:src="@drawable/bear"/>
    </LinearLayout>
    <Button android:id="@+id/btnGoMain" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="28dp" android:text="메인 화면으로 이동" android:background="@drawable/bg_button_red" android:backgroundTint="@color/flow_button_danger" android:textColor="@color/white" android:textAllCaps="false"/>
</LinearLayout>
