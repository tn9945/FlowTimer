<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/flow_ivory">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="집중 결과" android:textColor="@color/flow_text_primary" android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvSessionRange" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="세션 시간" android:textColor="@color/flow_text_hint" android:textSize="14sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <com.example.flowtimer.FocusResultDonutView android:id="@+id/viewResultDonut" android:layout_width="match_parent" android:layout_height="260dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="● 순집중" android:textColor="@color/flow_button_focus" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:text="● 휴식" android:textColor="@color/flow_button_stats" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:text="● 방해" android:textColor="@color/flow_button_danger" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="핵심 기록" android:textColor="@color/flow_text_primary" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvTotalDuration" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="총 측정 시간: 00시간 00분 00초" android:textSize="16sp"/>
            <TextView android:id="@+id/tvFocusDuration" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="순집중 시간: 00시간 00분 00초" android:textColor="@color/flow_button_focus" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvBreakDuration" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="휴식 시간: 00시간 00분 00초" android:textColor="@color/flow_button_stats" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvStudyDuration" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="학습 앱 사용 시간: 00시간 00분 00초" android:textSize="16sp"/>
            <TextView android:id="@+id/tvDistractionDuration" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="방해 앱 사용 시간: 00시간 00분 00초" android:textColor="@color/flow_button_danger" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvScore" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="집중 점수: 0점" android:textSize="16sp"/>
            <TextView android:id="@+id/tvSwitchCount" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="앱 전환 횟수: 0" android:textSize="16sp"/>
            <TextView android:id="@+id/tvTopApp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="가장 오래 사용한 앱: 기록 없음" android:textSize="16sp"/>
            <TextView android:id="@+id/tvReward" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="획득 보상: 코인 0 / 경험치 0 / 시간 0분" android:textSize="16sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI 집중 분석" android:textColor="@color/flow_text_primary" android:textSize="18sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvAiSummary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="AI 요약을 생성하고 있습니다." android:textColor="@color/flow_text_primary" android:textSize="15sp"/>
            <TextView android:id="@+id/tvAiWarning" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="AI 경고를 생성하고 있습니다." android:textColor="@color/flow_red" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvAiAdvice" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="AI 조언을 생성하고 있습니다." android:textColor="@color/flow_sky_dark" android:textSize="15sp" android:textStyle="bold"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="앱별 활동 기록" android:textColor="@color/flow_text_primary" android:textSize="18sp" android:textStyle="bold"/>
        <LinearLayout android:id="@+id/layoutAppRecords" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_summary_card" android:orientation="vertical" android:padding="8dp"/>
        <Button android:id="@+id/btnGoMain" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginHorizontal="12dp" android:layout_marginTop="24dp" android:background="@drawable/bg_button_red" android:backgroundTint="@color/flow_button_danger" android:text="메인 화면으로 이동" android:textColor="@color/white" android:textAllCaps="false"/>
    </LinearLayout>
</ScrollView>
